<UserControl x:Class="ImageEditor.Views.ToolbarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="40"
             Background="#2A2A2A">

    <UserControl.Resources>

        <Style x:Key="ToolButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="3,3,3,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#3E3E3E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#505050"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActiveToolButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolButtonStyle}">
            <Setter Property="Background" Value="#3A5A8A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#4A6A9A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Border BorderBrush="#444444" BorderThickness="0,0,1,0">
        <StackPanel Orientation="Vertical" Margin="0,4,0,0">

            <!-- Selection tool -->
            <Button x:Name="SelectionButton"
                    Style="{StaticResource ToolButtonStyle}"
                    ToolTip="Selection (S)"
                    Click="SelectionButton_Click">
                <Viewbox Width="18" Height="18">
                    <Canvas Width="24" Height="24">
                        <!-- Dashed rectangle icon -->
                        <Rectangle Canvas.Left="3" Canvas.Top="3"
                                   Width="18" Height="18"
                                   Stroke="#CCCCCC" StrokeThickness="2"
                                   StrokeDashArray="3,2"
                                   Fill="Transparent"/>
                    </Canvas>
                </Viewbox>
            </Button>

            <!-- Brush tool -->
            <Button x:Name="BrushButton"
                    Style="{StaticResource ToolButtonStyle}"
                    ToolTip="Brush (B)"
                    Click="BrushButton_Click">
                <Viewbox Width="18" Height="18">
                    <Canvas Width="24" Height="24">
                        <Rectangle Canvas.Left="10" Canvas.Top="1"
                                   Width="4" Height="13"
                                   RadiusX="2" RadiusY="2"
                                   Fill="#CCCCCC"/>
                        <Rectangle Canvas.Left="9.5" Canvas.Top="13"
                                   Width="5" Height="3"
                                   Fill="#888888"/>
                        <Ellipse Canvas.Left="9" Canvas.Top="15"
                                 Width="6" Height="8"
                                 Fill="#CCCCCC"/>
                        <Polygon Points="12,24 10,20 14,20"
                                 Fill="#AAAAAA"/>
                    </Canvas>
                </Viewbox>
            </Button>

            <!-- Line tool -->
            <Button x:Name="LineButton"
                    Style="{StaticResource ToolButtonStyle}"
                    ToolTip="Line (L)"
                    Click="LineButton_Click">
                <Viewbox Width="18" Height="18">
                    <Canvas Width="24" Height="24">
                        <Line X1="4" Y1="20" X2="20" Y2="4"
                              Stroke="#CCCCCC" StrokeThickness="2.5"/>
                    </Canvas>
                </Viewbox>
            </Button>

        </StackPanel>
    </Border>
</UserControl>