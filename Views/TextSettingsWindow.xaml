<Window x:Class="ImageEditor.Views.TextSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="NoResize"
        Background="#303030"
        Width="220"
        Height="195"
        Title="MonoFrame"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        WindowStartupLocation="Manual">

    <Border BorderBrush="#555555" BorderThickness="1">
        <DockPanel>

            <!-- Titlebar -->
            <Border DockPanel.Dock="Top"
                    Background="#303030"
                    Height="28"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    BorderBrush="#555555"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Text"
                               VerticalAlignment="Center"
                               Margin="10,0"
                               FontSize="12"
                               FontFamily="Segoe UI"
                               Foreground="#AAAAAA"/>

                    <Button Grid.Column="1"
                            Content="✕"
                            Width="28" Height="28"
                            FontSize="11"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="Close_Click">
                        <Button.Foreground>
                            <SolidColorBrush Color="#AAAAAA"/>
                        </Button.Foreground>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Border" Background="Transparent">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#E81123"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <StackPanel Margin="12,10,12,12">

                <!-- Font row -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Font" VerticalAlignment="Center"
                               FontSize="12" FontFamily="Segoe UI" Foreground="#CCCCCC"/>
                    <ComboBox x:Name="FontComboBox"
                              Grid.Column="1"
                              Height="22"
                              Background="#3C3C3C"
                              Foreground="White"
                              BorderBrush="#555555"
                              FontSize="12"
                              SelectionChanged="FontComboBox_SelectionChanged"/>
                </Grid>

                <!-- Size row -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="38"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Size" VerticalAlignment="Center"
                               FontSize="12" FontFamily="Segoe UI" Foreground="#CCCCCC"/>
                    <Slider x:Name="SizeSlider"
                            Grid.Column="1"
                            Minimum="6" Maximum="200" Value="16"
                            VerticalAlignment="Center"
                            ValueChanged="SizeSlider_ValueChanged"/>
                    <TextBox x:Name="SizeLabel"
                             Grid.Column="2" Height="22"
                             Background="#3C3C3C" Foreground="White"
                             BorderBrush="#555555" BorderThickness="1"
                             FontSize="12" FontFamily="Consolas"
                             Padding="2,2" CaretBrush="White"
                             MaxLength="3" Text="16" TextAlignment="Center"
                             KeyDown="SizeInput_KeyDown"
                             LostFocus="SizeInput_LostFocus"/>
                </Grid>

                <!-- Style row -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Style" VerticalAlignment="Center"
                               FontSize="12" FontFamily="Segoe UI" Foreground="#CCCCCC"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <ToggleButton x:Name="BoldButton"
                                      Width="28" Height="22"
                                      Content="B"
                                      FontWeight="Bold"
                                      FontSize="12"
                                      Margin="0,0,4,0"
                                      Checked="Style_Changed"
                                      Unchecked="Style_Changed">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton">
                                    <Setter Property="Background" Value="#3C3C3C"/>
                                    <Setter Property="Foreground" Value="#CCCCCC"/>
                                    <Setter Property="BorderBrush" Value="#555555"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter Property="Background" Value="#3A5A8A"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>
                        <ToggleButton x:Name="ItalicButton"
                                      Width="28" Height="22"
                                      Content="I"
                                      FontStyle="Italic"
                                      FontSize="12"
                                      Checked="Style_Changed"
                                      Unchecked="Style_Changed">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton">
                                    <Setter Property="Background" Value="#3C3C3C"/>
                                    <Setter Property="Foreground" Value="#CCCCCC"/>
                                    <Setter Property="BorderBrush" Value="#555555"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter Property="Background" Value="#3A5A8A"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>
                    </StackPanel>
                </Grid>

                <!-- Alignment row -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Align" VerticalAlignment="Center"
                               FontSize="12" FontFamily="Segoe UI" Foreground="#CCCCCC"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <RadioButton x:Name="AlignLeft" Content="L" IsChecked="True"
                                     Foreground="#CCCCCC" FontSize="12" Margin="0,0,8,0"
                                     VerticalAlignment="Center"
                                     Checked="Alignment_Changed"/>
                        <RadioButton x:Name="AlignCenter" Content="C"
                                     Foreground="#CCCCCC" FontSize="12" Margin="0,0,8,0"
                                     VerticalAlignment="Center"
                                     Checked="Alignment_Changed"/>
                        <RadioButton x:Name="AlignRight" Content="R"
                                     Foreground="#CCCCCC" FontSize="12"
                                     VerticalAlignment="Center"
                                     Checked="Alignment_Changed"/>
                    </StackPanel>
                </Grid>

            </StackPanel>
        </DockPanel>
    </Border>
</Window>