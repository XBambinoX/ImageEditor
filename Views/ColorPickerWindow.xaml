<Window x:Class="ImageEditor.Views.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="NoResize"
        Background="#303030"
        Width="220"
        Height="105"
        Title="MonoFrame"
        Topmost="True"
        Focusable="False"
        ShowActivated="False"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">

    <Border BorderBrush="#555555" BorderThickness="1">
        <DockPanel>

            <Border DockPanel.Dock="Top"
                    Background="#303030"
                    Height="28"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    BorderBrush="#555555"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Color" VerticalAlignment="Center" Margin="10,0"
                               FontSize="12" FontFamily="Segoe UI" Foreground="#AAAAAA"/>
                    <Button Grid.Column="1" Content="✕" Width="28" Height="28"
                            FontSize="11" BorderThickness="0" Cursor="Hand"
                            Click="Close_Click">
                        <Button.Foreground>
                            <SolidColorBrush Color="#AAAAAA"/>
                        </Button.Foreground>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Border" Background="Transparent">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#E81123"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <StackPanel Margin="12,10,12,12">

                <!-- Color swatch + popup -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Color" VerticalAlignment="Center"
                               FontSize="12" FontFamily="Segoe UI" Foreground="#CCCCCC"/>
                    <Border x:Name="ColorSwatch" Grid.Column="1"
                            Width="28" Height="22" HorizontalAlignment="Left"
                            BorderBrush="#666666" BorderThickness="1"
                            Cursor="Hand" MouseLeftButtonDown="ColorSwatch_Click">
                        <Border.Background>
                            <SolidColorBrush x:Name="SwatchBrush" Color="Black"/>
                        </Border.Background>
                    </Border>
                    <Popup x:Name="ColorPopup"
                           PlacementTarget="{Binding ElementName=ColorSwatch}"
                           Placement="Bottom" StaysOpen="True" AllowsTransparency="True">
                        <Border Background="#2A2A2A" BorderBrush="#555555" BorderThickness="1" Padding="6">
                            <WrapPanel Width="168" ItemWidth="24" ItemHeight="24">
                                <Border Background="Black"        Margin="2" Cursor="Hand" MouseLeftButtonUp="Color_Click"/>
                                <Border Background="#222222"      Margin="2" Cursor="Hand" MouseLeftButtonUp="Color_Click"/>
                                <Border Background="#555555"      Margin="2" Cursor="Hand" MouseLeftButtonUp="Color_Click"/>
                                <Border Background="#AAAAAA"      Margin="2" Cursor="Hand" MouseLeftButtonUp="Color_Click"/>
                                <Border Background="#DDDDDD"      Margin="2" Cursor="Hand" MouseLeftButtonUp="Color_Click"/>
                                <Border Background="White"        Margin="2" Cursor="Hand" MouseLeftButtonUp="Color_Click"/>
                                <Border Background="#8B0000"      Margin="2" Cursor="Hand" MouseLeftButtonUp="Color_Click"/>
                                <Border Background="Red"          Margin="2" Cursor="Hand" MouseLeftButtonUp="Color_Click"/>
                                <Border Background="OrangeRed"    Margin="2" Cursor="Hand" MouseLeftButtonUp="Color_Click"/>
                                <Border Background="Orange"       Margin="2" Cursor="Hand" MouseLeftButtonUp="Color_Click"/>
                                <Border Background="Yellow"       Margin="2" Cursor="Hand" MouseLeftButtonUp="Color_Click"/>
                                <Border Background="#FFD9B3"      Margin="2" Cursor="Hand" MouseLeftButtonUp="Color_Click"/>
                                <Border Background="#1b2a1b"      Margin="2" Cursor="Hand" MouseLeftButtonUp="Color_Click"/>
                                <Border Background="#556B2F"      Margin="2" Cursor="Hand" MouseLeftButtonUp="Color_Click"/>
                                <Border Background="Lime"         Margin="2" Cursor="Hand" MouseLeftButtonUp="Color_Click"/>
                                <Border Background="Teal"         Margin="2" Cursor="Hand" MouseLeftButtonUp="Color_Click"/>
                                <Border Background="#B3FFB3"      Margin="2" Cursor="Hand" MouseLeftButtonUp="Color_Click"/>
                                <Border Background="#F0FFF0"      Margin="2" Cursor="Hand" MouseLeftButtonUp="Color_Click"/>
                                <Border Background="#00008B"      Margin="2" Cursor="Hand" MouseLeftButtonUp="Color_Click"/>
                                <Border Background="DodgerBlue"   Margin="2" Cursor="Hand" MouseLeftButtonUp="Color_Click"/>
                                <Border Background="Cyan"         Margin="2" Cursor="Hand" MouseLeftButtonUp="Color_Click"/>
                                <Border Background="#B3D9FF"      Margin="2" Cursor="Hand" MouseLeftButtonUp="Color_Click"/>
                                <Border Background="#F0F8FF"      Margin="2" Cursor="Hand" MouseLeftButtonUp="Color_Click"/>
                                <Border Background="#16213e"      Margin="2" Cursor="Hand" MouseLeftButtonUp="Color_Click"/>
                                <Border Background="#4B0082"      Margin="2" Cursor="Hand" MouseLeftButtonUp="Color_Click"/>
                                <Border Background="BlueViolet"   Margin="2" Cursor="Hand" MouseLeftButtonUp="Color_Click"/>
                                <Border Background="MediumOrchid" Margin="2" Cursor="Hand" MouseLeftButtonUp="Color_Click"/>
                                <Border Background="DeepPink"     Margin="2" Cursor="Hand" MouseLeftButtonUp="Color_Click"/>
                                <Border Background="HotPink"      Margin="2" Cursor="Hand" MouseLeftButtonUp="Color_Click"/>
                                <Border Background="#FFB3B3"      Margin="2" Cursor="Hand" MouseLeftButtonUp="Color_Click"/>
                                <Border Background="#8B4513"      Margin="2" Cursor="Hand" MouseLeftButtonUp="Color_Click"/>
                                <Border Background="#3d2b1f"      Margin="2" Cursor="Hand" MouseLeftButtonUp="Color_Click"/>
                                <Border Background="#FFF8DC"      Margin="2" Cursor="Hand" MouseLeftButtonUp="Color_Click"/>
                                <Border Background="#FFFFB3"      Margin="2" Cursor="Hand" MouseLeftButtonUp="Color_Click"/>
                                <Border Background="#EEEEEE"      Margin="2" Cursor="Hand" MouseLeftButtonUp="Color_Click"/>
                                <Border Background="#1a1a2e"      Margin="2" Cursor="Hand" MouseLeftButtonUp="Color_Click"/>
                            </WrapPanel>
                        </Border>
                    </Popup>
                </Grid>

                <!-- Hex input -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Hex" VerticalAlignment="Center"
                               FontSize="12" FontFamily="Segoe UI" Foreground="#CCCCCC"/>
                    <TextBox x:Name="HexInput" Grid.Column="1"
                             Height="22" Background="#3C3C3C" Foreground="White"
                             BorderBrush="#555555" BorderThickness="1"
                             FontSize="12" FontFamily="Consolas" Padding="4,2"
                             CaretBrush="White" MaxLength="7" Text="#000000"
                             KeyDown="HexInput_KeyDown" LostFocus="HexInput_LostFocus"/>
                </Grid>
            </StackPanel>
        </DockPanel>
    </Border>
</Window>