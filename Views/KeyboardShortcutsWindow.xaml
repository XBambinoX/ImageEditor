<Window x:Class="ImageEditor.Views.KeyboardShortcutsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MonoFrame"
        Width="420" Height="520"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="NoResize"
        Background="#303030"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#555555" CornerRadius="4" Margin="2,0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="KeyText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <Style x:Key="ActionText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,12,0,0"/>
        </Style>

        <DataTemplate x:Key="ShortcutRow">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border BorderBrush="#555555" BorderThickness="0,0,1,1" Background="#3C3C3C">
                    <TextBlock Text="{Binding Key}" Style="{StaticResource KeyText}"/>
                </Border>
                <Border Grid.Column="1" BorderBrush="#555555" BorderThickness="0,0,0,1" Background="#3C3C3C">
                    <TextBlock Text="{Binding Action}" Style="{StaticResource ActionText}"/>
                </Border>
            </Grid>
        </DataTemplate>

        <Style x:Key="ShortcutList" TargetType="ItemsControl">
            <Setter Property="ItemTemplate" Value="{StaticResource ShortcutRow}"/>
        </Style>

    </Window.Resources>

    <Border BorderBrush="#555555" BorderThickness="1">
        <DockPanel>

            <!-- Titlebar -->
            <Border DockPanel.Dock="Top"
                    Background="#303030"
                    Height="28"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    BorderBrush="#555555"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Keyboard Shortcuts"
                               VerticalAlignment="Center"
                               Margin="10,0"
                               FontSize="16"
                               FontFamily="Segoe UI"
                               Foreground="#AAAAAA"/>

                    <Button Grid.Column="1"
                            Content="✕"
                            Width="28" Height="28"
                            FontSize="11"
                            FontFamily="Segoe UI"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="Close_Click">
                        <Button.Foreground>
                            <SolidColorBrush Color="#AAAAAA"/>
                        </Button.Foreground>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Border" Background="Transparent">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#E81123"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="16">
                <StackPanel>

                    <!-- Tools -->
                    <TextBlock Text="Tools" Style="{StaticResource SectionHeader}"/>
                    <Border BorderBrush="#555555" BorderThickness="1,1,1,0" Margin="0,4,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border BorderBrush="#555555" BorderThickness="0,0,1,1" Background="#444444">
                                <TextBlock Text="Shortcut" Style="{StaticResource HeaderText}"/>
                            </Border>
                            <Border Grid.Column="1" BorderBrush="#555555" BorderThickness="0,0,0,1" Background="#444444">
                                <TextBlock Text="Action" Style="{StaticResource HeaderText}"/>
                            </Border>
                        </Grid>
                    </Border>
                    <Border BorderBrush="#555555" BorderThickness="1,0,1,0">
                        <ItemsControl x:Name="ToolsGrid" Style="{StaticResource ShortcutList}"/>
                    </Border>

                    <!-- File -->
                    <TextBlock Text="File" Style="{StaticResource SectionHeader}"/>
                    <Border BorderBrush="#555555" BorderThickness="1,1,1,0" Margin="0,4,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border BorderBrush="#555555" BorderThickness="0,0,1,1" Background="#444444">
                                <TextBlock Text="Shortcut" Style="{StaticResource HeaderText}"/>
                            </Border>
                            <Border Grid.Column="1" BorderBrush="#555555" BorderThickness="0,0,0,1" Background="#444444">
                                <TextBlock Text="Action" Style="{StaticResource HeaderText}"/>
                            </Border>
                        </Grid>
                    </Border>
                    <Border BorderBrush="#555555" BorderThickness="1,0,1,0">
                        <ItemsControl x:Name="FileGrid" Style="{StaticResource ShortcutList}"/>
                    </Border>

                    <!-- Edit -->
                    <TextBlock Text="Edit" Style="{StaticResource SectionHeader}"/>
                    <Border BorderBrush="#555555" BorderThickness="1,1,1,0" Margin="0,4,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border BorderBrush="#555555" BorderThickness="0,0,1,1" Background="#444444">
                                <TextBlock Text="Shortcut" Style="{StaticResource HeaderText}"/>
                            </Border>
                            <Border Grid.Column="1" BorderBrush="#555555" BorderThickness="0,0,0,1" Background="#444444">
                                <TextBlock Text="Action" Style="{StaticResource HeaderText}"/>
                            </Border>
                        </Grid>
                    </Border>
                    <Border BorderBrush="#555555" BorderThickness="1,0,1,0">
                        <ItemsControl x:Name="EditGrid" Style="{StaticResource ShortcutList}"/>
                    </Border>

                    <!-- Canvas -->
                    <TextBlock Text="Canvas" Style="{StaticResource SectionHeader}"/>
                    <Border BorderBrush="#555555" BorderThickness="1,1,1,0" Margin="0,4,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border BorderBrush="#555555" BorderThickness="0,0,1,1" Background="#444444">
                                <TextBlock Text="Shortcut" Style="{StaticResource HeaderText}"/>
                            </Border>
                            <Border Grid.Column="1" BorderBrush="#555555" BorderThickness="0,0,0,1" Background="#444444">
                                <TextBlock Text="Action" Style="{StaticResource HeaderText}"/>
                            </Border>
                        </Grid>
                    </Border>
                    <Border BorderBrush="#555555" BorderThickness="1,0,1,0" Margin="0,0,0,16">
                        <ItemsControl x:Name="CanvasGrid" Style="{StaticResource ShortcutList}"/>
                    </Border>

                </StackPanel>
            </ScrollViewer>

        </DockPanel>
    </Border>
</Window>