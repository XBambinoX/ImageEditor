<Window x:Class="ImageEditor.Views.SharpenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ImageEditor.ViewModels"
        Title="Sharpen"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#2D2D30"
        Icon="/Assets/MonoFrame.ico">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- PREVIEW -->
        <Border Grid.Row="0"
                Background="#1E1E1E"
                CornerRadius="4"
                Padding="5">

            <Image Source="{Binding PreviewImage}"
                   Stretch="Uniform"/>
        </Border>

        <!-- CONTROLS -->
        <Grid Grid.Row="1" Margin="0,15,0,0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">

                <TextBlock Text="Strength:"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>

                <Button Content="-"
                        Width="30"
                        Height="25"
                        Margin="0,0,5,0"
                        Command="{Binding DecreaseStrengthCommand}"/>

                <Slider Width="300"
                        Minimum="{Binding MinStrength}"
                        Maximum="{Binding MaxStrength}"
                        Value="{Binding Strength, Mode=TwoWay}"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"/>

                <Button Content="+"
                        Width="30"
                        Height="25"
                        Margin="5,0,10,0"
                        Command="{Binding IncreaseStrengthCommand}"/>

                <TextBox Width="60"
                         Height="25"
                         Text="{Binding Strength, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         HorizontalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal">

                <Button Content="OK"
                        Width="80"
                        Margin="0,0,10,0"
                        Command="{Binding ApplyCommand}"/>

                <Button Content="Cancel"
                        Width="80"
                        Command="{Binding CancelCommand}"/>
            </StackPanel>

        </Grid>
    </Grid>
</Window>