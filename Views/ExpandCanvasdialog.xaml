<Window x:Class="ImageEditor.Views.ExpandCanvasdialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="NoResize"
        Background="#303030"
        Width="380"
        Height="185"
        WindowStartupLocation="CenterOwner"
        Title="MonoFrame">

    <Border BorderBrush="#555555" BorderThickness="1">
        <DockPanel>

            <!-- Titlebar -->
            <Border DockPanel.Dock="Top"
                    Background="#303030"
                    Height="30"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    BorderBrush="#555555"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Expand Canvas"
                               VerticalAlignment="Center"
                               Margin="10,0"
                               FontSize="13"
                               FontFamily="Segoe UI"
                               Foreground="#CCCCCC"/>

                    <Button Grid.Column="1"
                            Content="✕"
                            Width="30" Height="30"
                            FontSize="13"
                            FontFamily="Segoe UI"
                            Background="#303030"
                            Foreground="#CCCCCC"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="No_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Border" Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#E81123"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Margin="20,16,20,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           FontFamily="Segoe UI"
                           FontSize="13"
                           Foreground="#DDDDDD"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center">
                    <Run Text="The pasted image ("/>
                    <Run x:Name="PasteSizeRun" FontWeight="SemiBold" Foreground="White"/>
                    <Run Text=") is larger than the canvas ("/>
                    <Run x:Name="CanvasSizeRun" FontWeight="SemiBold" Foreground="White"/>
                    <Run Text=")."/>
                    <LineBreak/>
                    <LineBreak/>
                    <Run Text="Expand canvas to fit?"/>
                </TextBlock>

                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,12,0,0">

                    <Button Content="Expand"
                            Width="90" Height="30"
                            FontSize="13"
                            FontFamily="Segoe UI"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0,0,8,0"
                            Click="Yes_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Border" Background="#3A7BD5" CornerRadius="2">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#4A8BE5"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#2A6BC5"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Foreground>
                            <SolidColorBrush Color="White"/>
                        </Button.Foreground>
                    </Button>

                    <Button Content="No"
                            Width="90" Height="30"
                            FontSize="13"
                            FontFamily="Segoe UI"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="No_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Border" Background="#444444" CornerRadius="2">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#555555"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#606060"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Foreground>
                            <SolidColorBrush Color="White"/>
                        </Button.Foreground>
                    </Button>
                </StackPanel>
            </Grid>
        </DockPanel>
    </Border>
</Window>
