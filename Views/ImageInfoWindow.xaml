<Window x:Class="ImageEditor.Views.ImageInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Image Info"
        Height="450"
        Width="420"
        WindowStartupLocation="CenterOwner"
        Focusable="False"
        ShowActivated="False"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#2D2D30">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#555555"
                                                CornerRadius="4"
                                                Margin="2,0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#555555" BorderThickness="1">
        <DockPanel>

            <!-- TITLEBAR -->
            <Border DockPanel.Dock="Top"
                    Background="#303030"
                    Height="28"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    BorderBrush="#555555"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Image Info"
                               VerticalAlignment="Center"
                               Margin="10,0"
                               FontFamily="Segoe UI"
                               Foreground="#AAAAAA"/>

                    <Button Grid.Column="1"
                            Content="✕"
                            Width="28" Height="28"
                            FontSize="11"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="CloseButton_Click">
                        <Button.Foreground>
                            <SolidColorBrush Color="#AAAAAA"/>
                        </Button.Foreground>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Border" Background="Transparent">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#E81123"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- CONTENT -->
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- FILE -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Name" Foreground="#888888"/>
                            <TextBlock Grid.Column="1" Text="{Binding FileName}" Foreground="#CCCCCC" TextTrimming="CharacterEllipsis"/>
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Extension" Foreground="#888888"/>
                            <TextBlock Grid.Column="1" Text="{Binding Extension}" Foreground="#CCCCCC"/>
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="File Size" Foreground="#888888"/>
                            <TextBlock Grid.Column="1" Text="{Binding FileSize}" Foreground="#CCCCCC"/>
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Created" Foreground="#888888"/>
                            <TextBlock Grid.Column="1" Text="{Binding Created}" Foreground="#CCCCCC"/>
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Modified" Foreground="#888888"/>
                            <TextBlock Grid.Column="1" Text="{Binding Modified}" Foreground="#CCCCCC"/>
                        </Grid>

                        <Separator Background="#3F3F46" Margin="0,10,0,10"/>

                        <!-- IMAGE -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Dimensions" Foreground="#888888"/>
                            <TextBlock Grid.Column="1" Text="{Binding Dimensions}" Foreground="#CCCCCC"/>
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="DPI" Foreground="#888888"/>
                            <TextBlock Grid.Column="1" Foreground="#CCCCCC">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} , {1}">
                                        <Binding Path="DpiX"/>
                                        <Binding Path="DpiY"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Format" Foreground="#888888"/>
                            <TextBlock Grid.Column="1" Text="{Binding Format}" Foreground="#CCCCCC"/>
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Bit Depth" Foreground="#888888"/>
                            <TextBlock Grid.Column="1" Text="{Binding BitDepth}" Foreground="#CCCCCC"/>
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Memory" Foreground="#888888"/>
                            <TextBlock Grid.Column="1" Text="{Binding MemorySize}" Foreground="#CCCCCC"/>
                        </Grid>

                        <Separator Background="#3F3F46" Margin="0,10,0,10"/>

                        <!-- PATH -->
                        <TextBlock Text="PATH"
                   Foreground="#888888"
                   Margin="0,0,0,6"/>

                        <TextBlock Text="{Binding FilePath}"
                   Foreground="#CCCCCC"
                   TextWrapping="Wrap"/>

                    </StackPanel>
                </ScrollViewer>

                <Button Grid.Row="1"
                    Content="Close"
                    Width="110"
                    Height="28"
                    Margin="0,12,0,0"
                    HorizontalAlignment="Right"
                    Click="CloseButton_Click"
                    Background="#3C3C3C"
                    Foreground="#CCCCCC"
                    BorderBrush="#555555"
                    BorderThickness="1"
                    FontSize="13"
                    FontFamily="Segoe UI"
                    Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="#505050"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="#606060"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </DockPanel>
    </Border>
</Window>