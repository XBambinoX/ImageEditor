<Window x:Class="ImageEditor.Views.SobelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edge Detection (Sobel)"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#2D2D30"
        Icon="/Assets/MonoFrame.ico">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- PREVIEW -->
        <Border Grid.Row="0"
                Background="#1E1E1E"
                CornerRadius="4"
                Padding="5">
            <Image Source="{Binding PreviewImage}"
                   Stretch="Uniform"/>
        </Border>

        <!-- CONTROLS -->
        <Grid Grid.Row="1" Margin="0,15,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Threshold -->
            <StackPanel Grid.Row="0" Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="0,0,0,8">

                <TextBlock Text="Threshold:"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Width="75"
                           Margin="0,0,10,0"/>

                <Button Content="-"
                        Width="30" Height="25"
                        Margin="0,0,5,0"
                        Command="{Binding DecreaseThresholdCommand}"/>

                <Slider Width="300"
                        Minimum="{Binding MinThreshold}"
                        Maximum="{Binding MaxThreshold}"
                        Value="{Binding Threshold, Mode=TwoWay}"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        PreviewMouseWheel="Slider_MouseWheel"/>

                <Button Content="+"
                        Width="30" Height="25"
                        Margin="5,0,10,0"
                        Command="{Binding IncreaseThresholdCommand}"/>

                <TextBox Width="60" Height="25"
                         Text="{Binding Threshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         HorizontalContentAlignment="Center"/>

            </StackPanel>

            <!-- Colorize -->
            <StackPanel Grid.Row="1" Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">

                <TextBlock Text="Colorize:"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Width="75"
                           Margin="0,0,10,0"/>

                <CheckBox IsChecked="{Binding Colorize, Mode=TwoWay}"
                          VerticalAlignment="Center"
                          Foreground="White"
                          Content="Color edges by gradient direction"/>

            </StackPanel>

            <!-- OK / Cancel -->
            <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">

                <Button Content="OK"
                        Width="80"
                        Margin="0,0,10,0"
                        Command="{Binding ApplyCommand}"/>

                <Button Content="Cancel"
                        Width="80"
                        Command="{Binding CancelCommand}"/>

            </StackPanel>

        </Grid>
    </Grid>
</Window>